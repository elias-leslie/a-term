{
  "schema_version": 1,
  "project": {
    "id": "a-term",
    "repo_name": "a-term",
    "display_name": "A-Term",
    "legacy_ids": [
      "aterm",
      "terminal"
    ],
    "repo_aliases": [
      "aterm",
      "terminal"
    ]
  },
  "branding": {
    "short_name": "A-Term",
    "description": "Host-native browser workspace for persistent tmux, shell, and agent sessions."
  },
  "runtime": {
    "backend_port": 8002,
    "frontend_port": 3002,
    "backend_dir": ".",
    "frontend_dir": "frontend",
    "health_endpoint": "/health"
  },
  "services": {
    "backend": "a-term-backend.service",
    "frontend": "a-term-frontend.service",
    "default_workers": [],
    "optional_workers": []
  },
  "hosts": {
    "production_frontend": "a-term.summitflow.dev",
    "production_api": "a-term-api.summitflow.dev"
  },
  "artifacts": {
    "python_distribution": "a-term",
    "python_module": "a_term",
    "cache_dir_name": "a-term",
    "upload_dir_name": "a-term-uploads",
    "env_prefix": "A_TERM",
    "legacy_python_modules": [
      "aterm"
    ]
  },
  "database": {
    "shared_with": "summitflow",
    "table_prefix": "a_term_",
    "legacy_table_prefixes": [
      "aterm_",
      "terminal_"
    ],
    "version_table": "a_term_alembic_version",
    "legacy_version_tables": [
      "aterm_alembic_version",
      "terminal_alembic_version"
    ]
  },
  "repository": {
    "owner": "elias-leslie",
    "name": "a-term",
    "ssh_url": "git@github.com:elias-leslie/a-term.git",
    "https_url": "https://github.com/elias-leslie/a-term"
  }
}
