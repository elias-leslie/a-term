# Copy this file to .env.local, then run `bash scripts/install.sh`.
# Leave the placeholder DATABASE_URL below to let the installer bootstrap managed PostgreSQL automatically.
# The default path prefers Docker when it is already installed and falls back to a local user-managed PostgreSQL cluster otherwise.
# Set your own DATABASE_URL only when you want to use an existing PostgreSQL instance.

# Required
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/a-term

# Optional database pool tuning
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_MAX_WAITING=20
DB_POOL_MAX_LIFETIME_SECONDS=1800
DB_POOL_MAX_IDLE_SECONDS=300
DB_POOL_RECONNECT_TIMEOUT_SECONDS=30

# Service
A_TERM_PORT=8002
A_TERM_BIND_HOST=127.0.0.1
A_TERM_FRONTEND_PORT=3002
A_TERM_FRONTEND_HOST=127.0.0.1
LOG_LEVEL=INFO
LOG_DIR=logs
NEXT_PUBLIC_AGENT_HUB_URL=
AGENT_HUB_URL=
SUMMITFLOW_API_BASE=

# CORS origins must be valid JSON
CORS_ORIGINS=["http://localhost:3002"]

# Public auth
# Keep A_TERM_AUTH_MODE=none only for loopback-only development.
A_TERM_AUTH_MODE=none
# Required when A_TERM_AUTH_MODE=password
A_TERM_AUTH_PASSWORD=
# Required when A_TERM_AUTH_MODE=password or proxy
A_TERM_AUTH_SECRET=
A_TERM_AUTH_PROXY_HEADER=X-Forwarded-User
A_TERM_AUTH_COOKIE_SECURE=false
A_TERM_AUTH_SESSION_TTL_HOURS=168

# Uploads
MAX_FILE_SIZE_MB=10
# Defaults to ~/a-term-uploads. Uncomment to override it.
# UPLOAD_DIR=/home/YOUR_USER/a-term-uploads
UPLOAD_MAX_AGE_SECONDS=86400

# Maintenance
MAINTENANCE_ENABLED=true
MAINTENANCE_INTERVAL_SECONDS=900
MAINTENANCE_SESSION_PURGE_DAYS=7
