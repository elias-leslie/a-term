# SummitFlow Terminal reads settings from ~/.env.local by default.
# Use these values as placeholders in ~/.env.local or export them in your shell.

# Required
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/summitflow

# Optional database pool tuning
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_MAX_WAITING=20
DB_POOL_MAX_LIFETIME_SECONDS=1800
DB_POOL_MAX_IDLE_SECONDS=300
DB_POOL_RECONNECT_TIMEOUT_SECONDS=30

# Service
TERMINAL_PORT=8002
SUMMITFLOW_API_BASE=http://localhost:8001/api
LOG_LEVEL=INFO

# CORS origins must be valid JSON
CORS_ORIGINS=["https://terminal.summitflow.dev","http://localhost:3002"]

# Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=/home/YOUR_USER/terminal-uploads
UPLOAD_MAX_AGE_SECONDS=86400

# Maintenance
MAINTENANCE_ENABLED=true
MAINTENANCE_INTERVAL_SECONDS=900
MAINTENANCE_SESSION_PURGE_DAYS=7
