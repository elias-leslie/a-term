[Unit]
Description=A-Term Backend (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_ROOT__
Environment="PATH=%h/bin:%h/.local/bin:__PROJECT_ROOT__/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="HOME=%h"
EnvironmentFile=-%h/.env.local
Environment="SUMMITFLOW_API_BASE=http://localhost:8001/api"
ExecStart=/bin/bash -lc '__PROJECT_ROOT__/.venv/bin/uvicorn aterm.main:app --host "${ATERM_BIND_HOST:-0.0.0.0}" --port "${ATERM_BACKEND_PORT:-8002}"'
Restart=always
RestartSec=10
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=aterm-backend

[Install]
WantedBy=default.target
